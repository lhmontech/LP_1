            <Image url="@imagens/cabelo.jpg" />
         </image>
      </ImageView>
      <Button layoutX="102.0" layoutY="103.0" mnemonicParsing="false" onAction="#clicarBtnPintar" prefHeight="45.0" prefWidth="98.0" text="Pintar">
