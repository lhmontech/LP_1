            <Font size="21.0" />
         </font>
      </Button>
      <Button layoutX="99.0" layoutY="232.0" mnemonicParsing="false" onAction="#clicarBtnLavar" prefHeight="45.0" prefWidth="98.0" text="Lavar">
         <font>
            <Font size="21.0" />
         </font>
      </Button>
      <Button layoutX="124.0" layoutY="306.0" mnemonicParsing="false" onAction="#clicarBtnVoltar" text="Voltar" />
      <Label fx:id="texto" alignment="CENTER" contentDisplay="CENTER" layoutX="67.0" layoutY="21.0" prefHeight="73.0" prefWidth="551.0" textAlignment="CENTER" wrapText="true">
