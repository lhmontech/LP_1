<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="434.0" prefWidth="735.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.farmaciaController">
   <children>
      <ImageView fitHeight="242.0" fitWidth="272.0" layoutX="279.0" layoutY="70.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@imagens/remédio.jpeg" />
         </image>
      </ImageView>
      <Button layoutX="86.0" layoutY="78.0" mnemonicParsing="false" onAction="#clicarBtnTomar" prefHeight="45.0" prefWidth="134.0" text="Tomar">
         <font>
            <Font size="21.0" />
         </font>
      </Button>
      <Button layoutX="104.0" layoutY="140.0" mnemonicParsing="false" onAction="#clicarBtnCurar" prefHeight="41.0" prefWidth="98.0" text="Curar">
         <font>
            <Font size="21.0" />
         </font>
      </Button>
      <Button layoutX="85.0" layoutY="206.0" mnemonicParsing="false" onAction="#clicarBtnComprar" prefHeight="45.0" prefWidth="134.0" text="Comprar">
         <font>
            <Font size="21.0" />
         </font>
      </Button>
      <Button layoutX="126.0" layoutY="280.0" mnemonicParsing="false" onAction="#clicarBtnVoltar" text="Voltar" />
      <Label fx:id="texto" alignment="CENTER" contentDisplay="CENTER" layoutX="67.0" layoutY="21.0" prefHeight="36.0" prefWidth="551.0" textAlignment="CENTER" wrapText="true">
