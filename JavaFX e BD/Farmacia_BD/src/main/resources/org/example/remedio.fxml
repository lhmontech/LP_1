                  </Label>
                  <TextField fx:id="fldPreco" maxWidth="100.0" styleClass="txt_field" stylesheets="@../../css/style.css" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="Desconto (%):">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <TextField fx:id="fldDesconto" maxWidth="100.0" styleClass="txt_field" stylesheets="@../../css/style.css" />
               </children>
            </HBox>
         </children>
      </HBox>
      <Label alignment="CENTER" layoutX="229.0" text="Cadastro de produtos" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="10.0">
