                     </children>
                  </HBox>
                  <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../images/amoxicilina.png" />
                     </image>
                  </ImageView>
                  <RadioButton fx:id="rsAmoxicilina" mnemonicParsing="false" styleClass="radio_btn" stylesheets="@../../css/style.css" text="Amoxicilina" />
               </children>
            </VBox>
            <VBox alignment="BOTTOM_CENTER">
